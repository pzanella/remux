{
  "name": "remux",
  "version": "1.0.0",
  "description": "Convert MP4/MOV to adaptive HLS entirely in the browser, with hardware-accelerated multi-resolution encoding via WebCodecs — no server, no upload.",
  "keywords": [
    "hls",
    "m3u8",
    "video",
    "video-processing",
    "video-editor",
    "transcoding",
    "remux",
    "streaming",
    "adaptive-bitrate",
    "webcodecs",
    "webassembly",
    "wasm",
    "rust",
    "ffmpeg",
    "shaka-player",
    "subtitles",
    "browser",
    "client-side"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.20.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build:wasm": "cd wasm && RUSTUP_TOOLCHAIN=stable wasm-pack build --target bundler --out-dir ../packages/remux-core && cp ../LICENSE ../packages/remux-core/",
    "dev:full": "npm run build:wasm && vite"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shaka-player": "^5.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^5.4.11",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0"
  }
}
